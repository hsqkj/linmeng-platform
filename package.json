{
  "name": "linmeng-marketing-assistant",
  "version": "1.0.0",
  "description": "邻盟营销助手 - 社区商户智能营销推广平台",
  "main": "index.html",
  "scripts": {
    "start": "http-server -p 8000 -c-1",
    "dev": "http-server -p 8000 -c-1 -o",
    "install-deps": "npm install -g http-server",
    "build:css": "npx tailwindcss -i ./css/styles.css -o ./css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./css/styles.css -o ./css/output.css --watch"
  },
  "keywords": [
    "marketing",
    "community",
    "business",
    "promotion",
    "social-commerce"
  ],
  "author": "邻盟营销助手团队",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/business-district-news.git"
  },
  "bugs": {
    "url": "https://github.com/your-repo/business-district-news/issues"
  },
  "homepage": "https://github.com/your-repo/business-district-news#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "http-server": "^14.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}

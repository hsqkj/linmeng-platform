{
  "name": "linmeng-platform",
  "version": "1.0.0",
  "description": "邻盟社区活动与商业资源智能对接助手",
  "private": true,
  "workspaces": [
    "server",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:community\" \"npm run dev:merchant\" \"npm run dev:admin\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:community": "npm run dev --workspace=apps/community-h5",
    "dev:merchant": "npm run dev --workspace=apps/merchant-h5",
    "dev:admin": "npm run dev --workspace=apps/admin-web",
    "build": "npm run build --workspaces",
    "install:all": "npm install && npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
